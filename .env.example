# Скопируйте в .env и подставьте значения (файл .env в git не попадает).
# Можно оставить пустым: тогда URL и anon key задаются в UI при регистрации / в настройках.

# URL проекта Supabase, например https://xxxx.supabase.co
# VITE_SUPABASE_URL=

# Публичный (anon) ключ из Project Settings → API
# VITE_SUPABASE_ANON_KEY=

# Имя бота без @ для ссылки «Открыть бота для привязки» в настройках (после миграции 006)
# VITE_TELEGRAM_BOT_USERNAME=design_flow_bot
