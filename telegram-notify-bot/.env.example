# Токен от @BotFather
BOT_TOKEN=

# Тот же проект, что и у веб-приложения
SUPABASE_URL=https://xxxx.supabase.co

# Только на сервере / у воркера — не во фронтенде
SUPABASE_SERVICE_ROLE_KEY=

# Календарные дни для дедлайнов и dedupe (например Europe/Moscow)
NOTIFY_TIMEZONE=Europe/Moscow

# Интервал проверки дедлайнов, мс (по умолчанию 1 час)
DEADLINE_POLL_MS=3600000

# Интервал проверки напоминаний задач (reminder_preset/custom), мс (по умолчанию 1 минута)
TASK_REMINDER_POLL_MS=60000

# Догоняющее окно: если воркер был выключен, отправит напоминания за это время назад (мс).
# По умолчанию 24 часа.
TASK_REMINDER_CATCHUP_MS=86400000
